{
  "name": "@mermer/contracts",
  "private": true,
  "scripts": {
    "node": "HOME=.hardhat-home hardhat node --hostname 127.0.0.1",
    "compile": "HOME=.hardhat-home hardhat compile",
    "test": "HOME=.hardhat-home hardhat test",
    "sync:generated": "node scripts/sync-generated.js",
    "deploy:local": "HOME=.hardhat-home hardhat run scripts/deploy-contracts.js",
    "deploy:localhost": "HOME=.hardhat-home hardhat run scripts/deploy-contracts.js --network localhost",
    "deploy:sepolia": "HOME=.hardhat-home hardhat run scripts/deploy-contracts.js --network sepolia",
    "mint:test-usd:localhost": "HOME=.hardhat-home hardhat run scripts/mint-test-usd.js --network localhost",
    "mint:test-usd:sepolia": "HOME=.hardhat-home hardhat run scripts/mint-test-usd.js --network sepolia",
    "project:payment:localhost": "HOME=.hardhat-home hardhat run scripts/project-finalized-payment.js --network localhost",
    "project:payment:sepolia": "HOME=.hardhat-home hardhat run scripts/project-finalized-payment.js --network sepolia",
    "verify:sepolia": "HOME=.hardhat-home hardhat run scripts/verify-sepolia-readiness.js --network sepolia",
    "smoke:local-invoice": "HOME=.hardhat-home hardhat run scripts/smoke-local-invoice.js --network localhost"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.19",
    "typescript": "^5.9.3"
  }
}
