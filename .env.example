# Mermer Pay local defaults.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
# Contract environment: dev/local aliases resolve to local-dev. Public testnets are paused.
MERMER_CONTRACT_ENV=local-dev
NEXT_PUBLIC_CONTRACT_ENV=local-dev
NEXT_PUBLIC_CARDFORGE_DEMO_URL=http://127.0.0.1:3002
MERMER_API_BASE_URL=http://127.0.0.1:8080
MERMER_OPERATOR_KEY=local-operator-dev-key
MERMER_WEBHOOK_SECRET=local-webhook-dev-secret
MERMER_GATEWAY_CALLBACK_KEY=local-zama-gateway-dev-key
DATABASE_URL=postgres://mermer:mermer@127.0.0.1:5432/mermer
MERMER_LOCAL_LOGIN_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
MERMER_ENABLE_DEV_SIGNER=0

# Independent CardForge template demo.
# Frontend values live in demo/cardforge/frontend/.env.local.
NEXT_PUBLIC_CARDFORGE_API_URL=http://127.0.0.1:8092
NEXT_PUBLIC_MERMER_PAY_CONSOLE_URL=http://127.0.0.1:3001/merchant

# Backend values live in the cardforge-backend process environment.
CARDFORGE_BACKEND_BIND=127.0.0.1:8092
CARDFORGE_MERCHANT_LABEL=CardForge Demo Store
CARDFORGE_WEBHOOK_ENDPOINT=http://127.0.0.1:8092/api/mermer-pay/webhook
MERMER_PAY_API_URL=http://127.0.0.1:8080
MERMER_PAY_CHECKOUT_BASE_URL=http://127.0.0.1:3001
MERMER_PAY_CONSOLE_URL=http://127.0.0.1:3001/merchant
MERMER_PAY_LOGIN_URL=http://127.0.0.1:3001/login
MERMER_PAY_PROJECT_ID=default-merchant-project

CONFIRMATIONS=2
FINALITY_THRESHOLD=2
