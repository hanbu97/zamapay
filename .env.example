# ZamaPay local defaults.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
# Contract environment: dev/local aliases resolve to local-dev. Public testnets are paused.
ZAMAPAY_CONTRACT_ENV=local-dev
NEXT_PUBLIC_CONTRACT_ENV=local-dev
NEXT_PUBLIC_CARDFORGE_DEMO_URL=http://127.0.0.1:3002
ZAMAPAY_API_BASE_URL=http://127.0.0.1:8080
ZAMAPAY_OPERATOR_KEY=local-operator-dev-key
ZAMAPAY_WEBHOOK_SECRET=local-webhook-dev-secret
ZAMAPAY_GATEWAY_CALLBACK_KEY=local-zama-gateway-dev-key
DATABASE_URL=postgres://zamapay:zamapay@127.0.0.1:5432/zamapay
ZAMAPAY_LOCAL_LOGIN_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ZAMAPAY_ENABLE_DEV_SIGNER=0

# Independent CardForge template demo.
# Frontend values live in demo/cardforge/frontend/.env.local.
NEXT_PUBLIC_CARDFORGE_API_URL=http://127.0.0.1:8092
NEXT_PUBLIC_ZAMAPAY_CONSOLE_URL=http://127.0.0.1:3001/merchant

# Backend values live in the cardforge-backend process environment.
CARDFORGE_BACKEND_BIND=127.0.0.1:8092
CARDFORGE_DATABASE_URL=postgres://zamapay:zamapay@127.0.0.1:5432/cardforge
CARDFORGE_MERCHANT_LABEL=CardForge Demo Store
CARDFORGE_STORE_KEY=local-dev
CARDFORGE_WEBHOOK_ENDPOINT=http://127.0.0.1:8092/api/zamapay/webhook
ZAMAPAY_API_URL=http://127.0.0.1:8080
ZAMAPAY_CHECKOUT_BASE_URL=http://127.0.0.1:3001
ZAMAPAY_CONSOLE_URL=http://127.0.0.1:3001/merchant
ZAMAPAY_LOGIN_URL=http://127.0.0.1:3001/login
ZAMAPAY_PROJECT_ID=default-merchant-project

CONFIRMATIONS=2
FINALITY_THRESHOLD=2
