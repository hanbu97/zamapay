# Root .env is intentionally not the canonical service contract anymore.
# Use the split process files under env/ instead:
#
# - env/local-dev.zamapay-api.env.example
# - env/local-dev.zamapay-web.env.example
# - env/local-dev.cardforge-backend.env.example
# - env/local-dev.cardforge-frontend.env.example
# - env/supabase.zamapay-api.env.example
# - env/supabase.cardforge-backend.env.example
#
# Same-name files without .example are local secret files and are git-ignored.
