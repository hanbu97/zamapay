{
  "name": "zamapay",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "contracts",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:sdk": "npm --workspace @zamapay/server run build",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:sdk": "npm --workspace @zamapay/server run lint",
    "test:web": "npm --workspace apps/web run test",
    "test:sdk": "npm --workspace @zamapay/server run test",
    "test:sdk-install-shape": "npm --workspace @zamapay/server run test:install-shape",
    "test:contracts": "npm --workspace contracts run test"
  }
}
