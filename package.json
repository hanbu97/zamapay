{
  "name": "mermer-pay",
  "private": true,
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "apps/*",
    "contracts"
  ],
  "scripts": {
    "build": "npm run build:web",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "test:web": "npm --workspace apps/web run test",
    "test:contracts": "npm --workspace contracts run test",
    "verify:local": "node scripts/local-readiness.js",
    "verify:local:full": "node scripts/local-full-verify.js"
  }
}
