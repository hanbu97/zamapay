# CardForge Next.js storefront, local-dev.
# Browser-safe only. Copy to env/local-dev.cardforge-frontend.env if needed.

NEXT_PUBLIC_CARDFORGE_API_URL=http://127.0.0.1:8092
NEXT_PUBLIC_ZAMAPAY_CONSOLE_URL=http://127.0.0.1:3001/merchant
NEXT_PUBLIC_RUNTIME_PROFILE=local-dev

# Optional local explorer URL. Leave empty if no local explorer is running.
NEXT_PUBLIC_LOCAL_EXPLORER_URL=
