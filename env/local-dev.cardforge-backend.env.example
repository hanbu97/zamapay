# CardForge Rust backend, local-dev.
# Copy this template to env/local-dev.cardforge-backend.env.
# Only the merchant project secret below comes from the ZamaPay console export.

CARDFORGE_BACKEND_BIND=127.0.0.1:8092
CARDFORGE_ALLOWED_ORIGINS=http://127.0.0.1:3002
CARDFORGE_DATABASE_URL=postgres://zamapay:zamapay@127.0.0.1:5432/cardforge
CARDFORGE_MERCHANT_LABEL=CardForge Demo Store
CARDFORGE_STORE_KEY=local-dev
CARDFORGE_WEBHOOK_ENDPOINT=http://127.0.0.1:8092/api/zamapay/webhook
CARDFORGE_PAYMENT_RAIL=zama_private
CARDFORGE_EVM_CHAIN_ID=31337
CARDFORGE_EVM_TOKEN_SYMBOL=USDT

# Shared deployment endpoints. These are not project-specific.
ZAMAPAY_API_URL=http://127.0.0.1:18080
ZAMAPAY_CHAIN_INVOICE_API_URL=http://127.0.0.1:3001
ZAMAPAY_CONSOLE_URL=http://127.0.0.1:3001/merchant
ZAMAPAY_LOGIN_URL=http://127.0.0.1:3001/login

# Merchant project secret. This single server-side value is shown once by ZamaPay.
ZAMAPAY_SECRET_KEY=zms_test_replace_with_console_value
