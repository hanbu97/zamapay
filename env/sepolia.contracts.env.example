# Contract deployment, Sepolia.
# Copy to env/sepolia.contracts.env and keep the real file out of git.

SEPOLIA_RPC_URL=https://replace-with-your-sepolia-rpc
DEPLOYER_PRIVATE_KEY=0xreplace_with_deployer_private_key

# Optional. Defaults to the deployer address when unset.
ZAMAPAY_PLATFORM_FEE_WALLET=
