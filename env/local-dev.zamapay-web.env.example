# ZamaPay Next.js web, local-dev.
# Copy to env/local-dev.zamapay-web.env and edit server-only values locally.

# Browser-safe values.
NEXT_PUBLIC_RUNTIME_PROFILE=local-dev
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001
NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CARDFORGE_DEMO_URL=http://127.0.0.1:3002
NEXT_PUBLIC_DEFAULT_PROJECT_WEBHOOK_URL=http://127.0.0.1:8092/api/zamapay/webhook
NEXT_PUBLIC_ZAMAPAY_CHAIN_INVOICE_API_URL=http://127.0.0.1:3001

# Server-side bridge values used by Next.js route handlers.
ZAMAPAY_RUNTIME_PROFILE=local-dev
ZAMAPAY_API_BASE_URL=http://127.0.0.1:8080
ZAMAPAY_OPERATOR_KEY=local-operator-dev-key
ZAMAPAY_GATEWAY_CALLBACK_KEY=local-zama-gateway-dev-key

# Local browser-login helper. Keep disabled unless doing walletless QA.
ZAMAPAY_ENABLE_DEV_SIGNER=0
ZAMAPAY_LOCAL_LOGIN_PRIVATE_KEY=

# Local finality projection defaults.
CONFIRMATIONS=2
FINALITY_THRESHOLD=2
