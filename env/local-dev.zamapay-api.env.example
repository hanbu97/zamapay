# ZamaPay Rust API, local-dev.
# Copy to env/local-dev.zamapay-api.env and edit secrets locally.

ZAMAPAY_API_BIND=127.0.0.1:8080
ZAMAPAY_RUNTIME_PROFILE=local-dev
DATABASE_URL=postgres://zamapay:zamapay@127.0.0.1:5432/zamapay

# Server-only keys. Replace before any public deployment.
ZAMAPAY_OPERATOR_KEY=local-operator-dev-key
ZAMAPAY_GATEWAY_CALLBACK_KEY=local-zama-gateway-dev-key
ZAMAPAY_WEBHOOK_SECRET=local-webhook-dev-secret

# Hosted checkout URLs generated by the API.
ZAMAPAY_CHECKOUT_BASE_URL=http://127.0.0.1:3001
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001

# Optional default webhook used by fallback project setup.
ZAMAPAY_WEBHOOK_ENDPOINT=http://127.0.0.1:8092/api/zamapay/webhook
