# ZamaPay Next.js web, Sepolia contracts.
# Source after any API/operator local env if you are composing files.

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_CONTRACT_ENV=sepolia
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://replace-with-your-sepolia-rpc
NEXT_PUBLIC_CARDFORGE_DEMO_URL=http://127.0.0.1:3002

# Browser FHE encrypt/decrypt calls use @zama-fhe/relayer-sdk SepoliaConfig.
# Do not point Sepolia at the local Hardhat fhevm_relayer_* RPC methods.

ZAMAPAY_API_BASE_URL=http://127.0.0.1:8080
ZAMAPAY_CONTRACT_ENV=sepolia
ZAMAPAY_CHAIN_INVOICE_PRIVATE_KEY=
SEPOLIA_RPC_URL=https://replace-with-your-sepolia-rpc

# Keep dev signer and local chain submitter disabled on Sepolia.
ZAMAPAY_ENABLE_DEV_SIGNER=0
ZAMAPAY_LOCAL_LOGIN_PRIVATE_KEY=

CONFIRMATIONS=2
FINALITY_THRESHOLD=2
